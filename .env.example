OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1

# Athletic update email notifications (used by run-all and check-athletic-update)
# Simple Gmail sender credentials
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your_google_app_password
GMAIL_TO=you@example.com

# Optional: make Athletic update check use Playwright fetch mode
BRACKET_MATRIX_CHECK_ATHLETIC_USE_PLAYWRIGHT=false
